      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <div v-if="featureFlags.ticketsEnabled" class="ui-surface p-4">
          <div class="ui-surface-title">Open tickets</div>
          <div class="mt-1 text-2xl font-semibold text-white">2</div>
          <RouterLink v-if="featureFlags.ticketsEnabled" to="/app/tickets" class="mt-2 ui-btn-secondary ui-btn-xs">View</RouterLink>
        </div>
        <div v-if="featureFlags.invoicesEnabled" class="ui-surface p-4">
          <div class="ui-surface-title">
            {{ overdueInvoices.length ? 'Overdue invoices' : 'Invoices outstanding' }}
          </div>
          <div class="mt-1 text-2xl font-semibold" :class="overdueInvoices.length ? 'text-rose-300' : 'text-white'">
            <span v-if="!invoicesLoaded" role="status" class="inline-flex align-middle">
              <span class="inline-block h-7 w-12 rounded-full bg-gray-200 dark:bg-gray-700 animate-pulse"></span>
              <span class="sr-only">Loading...</span>
            </span>
            <span v-else>{{ outstandingInvoices.length }}</span>
