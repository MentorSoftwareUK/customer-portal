<script setup lang="ts">
import { computed, onMounted, ref } from 'vue'
import { listInvoices, type InvoiceDto } from '../lib/api'
import { useFeatureFlags } from '../lib/featureFlags'
import { provisionFilterLabel, readProvisionFilter, type ProvisionFilter } from '../lib/provision'

const provision = ref<ProvisionFilter>(readProvisionFilter())
const provisionLabel = computed(() => provisionFilterLabel(provision.value))

const invoices = ref<InvoiceDto[]>([])
const invoicesLoaded = ref(false)
const { featureFlags, loadFeatureFlags } = useFeatureFlags()

const overdueInvoices = computed(() => invoices.value.filter((i) => i.status === 'Overdue'))
const outstandingInvoices = computed(() => invoices.value.filter((i) => i.status !== 'Paid'))

const mostUrgentInvoice = computed(() => {
  const overdue = overdueInvoices.value
  if (overdue.length) return overdue[0]
  const outstanding = outstandingInvoices.value
  return outstanding.length ? outstanding[0] : null
})

const showInvoiceAlert = ref(true)

onMounted(async () => {
  await loadFeatureFlags()
  if (!featureFlags.value.invoicesEnabled) {
    invoices.value = []
    invoicesLoaded.value = true
    return
  }
  try {
    const data = await listInvoices()
    invoices.value = data.invoices
  } catch {
    invoices.value = []
  } finally {
    invoicesLoaded.value = true
  }
})
</script>

<template>
  <div class="space-y-6">
      <div
        v-if="featureFlags.invoicesEnabled && invoicesLoaded && showInvoiceAlert && overdueInvoices.length"
        id="alert-overdue"
        class="flex sm:items-center p-4 text-sm rounded-base border border-rose-200 bg-rose-100 text-rose-950 border-l-4 border-l-rose-600"
        role="alert"
      >
        <svg class="w-4 h-4 shrink-0 mt-0.5 md:mt-0" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
          <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 11h2v5m-2 0h4m-2.592-8.5h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
        </svg>
        <span class="sr-only">Alert</span>
        <div class="ms-2 text-sm">
          <span class="font-medium">Action required:</span> you have {{ overdueInvoices.length }} overdue invoice{{ overdueInvoices.length === 1 ? '' : 's' }}.
          <RouterLink to="/app/invoices" class="font-semibold underline decoration-rose-500 hover:no-underline">View invoices</RouterLink>.
        </div>
        <button
          type="button"
          class="ms-auto -mx-1.5 -my-1.5 rounded focus:ring-2 focus:ring-rose-200 p-1.5 hover:bg-rose-200 inline-flex items-center justify-center h-8 w-8 shrink-0"
          aria-label="Close"
          @click="showInvoiceAlert = false"
        >
          <span class="sr-only">Close</span>
          <svg class="w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18 17.94 6M18 18 6.06 6"/>
          </svg>
        </button>
      </div>

      <div
        v-else-if="featureFlags.invoicesEnabled && invoicesLoaded && showInvoiceAlert && outstandingInvoices.length"
        id="alert-outstanding"
        class="flex sm:items-center p-4 text-sm text-fg-warning rounded-base bg-warning-soft"
        role="alert"
      >
        <svg class="w-4 h-4 shrink-0 mt-0.5 md:mt-0" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
          <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 11h2v5m-2 0h4m-2.592-8.5h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
        </svg>
        <span class="sr-only">Alert</span>
        <div class="ms-2 text-sm">
