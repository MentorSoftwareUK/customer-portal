        <button
          type="button"
          class="ms-auto -mx-1.5 -my-1.5 rounded focus:ring-2 focus:ring-warning-medium p-1.5 hover:bg-warning-medium inline-flex items-center justify-center h-8 w-8 shrink-0"
          aria-label="Close"
          @click="showInvoiceAlert = false"
        >
          <span class="sr-only">Close</span>
          <svg class="w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18 17.94 6M18 18 6.06 6"/>
          </svg>
        </button>
      </div>

      <div class="ui-surface p-6">
        <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
          <div>
            <h2 class="text-xl font-semibold text-white">Hi, welcome back</h2>
            <p class="mt-1 text-sm text-white/60">
              Your dashboard adapts to your provision type (currently: {{ provisionLabel }}).
            </p>
            <p class="mt-3 text-sm text-white/70">
              You have <span class="font-semibold">2</span> upcoming events and <span class="font-semibold">1</span> meeting this week.
              There are <span class="font-semibold">2</span> items that need your attention.
            </p>
          </div>

          <div class="flex flex-col sm:flex-row gap-2">
