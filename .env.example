# API
PORT=3001
NODE_ENV=development

# Portal base URL (used for payment redirect URLs)
PORTAL_BASE_URL=http://localhost:5173

# MongoDB (optional for now; if unset API uses demo/in-memory data)
MONGODB_URI=
MONGODB_DB=mentor_cp

# HubSpot (Private App Token recommended)
HUBSPOT_PRIVATE_APP_TOKEN=

# HubSpot OAuth (for Knowledge Base API access)
# Create an MCP Auth App in HubSpot developer settings to get these credentials.
HUBSPOT_OAUTH_CLIENT_ID=
HUBSPOT_OAUTH_CLIENT_SECRET=
HUBSPOT_OAUTH_REDIRECT_URI=http://localhost:3001/api/hubspot/oauth/callback

# HubSpot event registrations (recommended for reporting)
# If your HubSpot plan doesn't support Custom Objects, the repo supports a Deal-based model:
# 1 Deal = 1 registration, with a dedicated pipeline and stages.

# Pipeline: set either the pipeline id or label.
HUBSPOT_EVENT_REGISTRATION_DEAL_PIPELINE_ID=
HUBSPOT_EVENT_REGISTRATION_DEAL_PIPELINE_LABEL=Event Registrations

# Stage labels (preferred) or stage ids.
HUBSPOT_EVENT_REGISTRATION_STAGE_REGISTERED=Registered
HUBSPOT_EVENT_REGISTRATION_STAGE_PAYMENT_PENDING=Payment Pending
HUBSPOT_EVENT_REGISTRATION_STAGE_PAID=Paid
HUBSPOT_EVENT_REGISTRATION_STAGE_CANCELLED=Cancelled
HUBSPOT_EVENT_REGISTRATION_STAGE_FAILED=Failed

# Idempotency: create a Deal property and use it as the unique key.
# Recommended: create a single-line text property on Deals called mentor_registration_id.
HUBSPOT_EVENT_REGISTRATION_DEAL_UNIQUE_PROPERTY=mentor_registration_id

# HubSpot registration reporting via Custom Object (Option B)
# Requires HubSpot Enterprise. Leave blank to use Deals-only reporting.
HUBSPOT_EVENT_REGISTRATION_OBJECT_TYPE=
HUBSPOT_EVENT_REGISTRATION_OBJECT_UNIQUE_PROPERTY=mentor_registration_id

# HubSpot “live customer” mapping (optional)
# Used by POST /auth/lookup to set isLiveCustomer.
#
# Example:
# HUBSPOT_LIVE_CUSTOMER_PROPERTY=salesstatus
# HUBSPOT_LIVE_CUSTOMER_TRUE_VALUES=paying_customer
HUBSPOT_LIVE_CUSTOMER_PROPERTY=
HUBSPOT_LIVE_CUSTOMER_TRUE_VALUES=

# HubSpot provision type mapping (optional)
# Used by POST /auth/lookup to return a normalized provisionType for dashboard/content gating.
# Expected HubSpot values are usually along the lines of:
#  - Supported Accommodation
#  - Children's Home
#  - 18+ Services
HUBSPOT_PROVISION_TYPE_PROPERTY=

# HubSpot product version mapping (optional)
# Used by POST /auth/lookup to return a normalized productVersion (v2 vs v3) for version-specific content.
# Expected HubSpot values can be any of:
#  - 2, v2, Version 2, FileMaker
#  - 3, v3, Version 3, Web
HUBSPOT_PRODUCT_VERSION_PROPERTY=

# HubSpot content sources (Knowledge Base + Videos)
# Knowledge base language code (e.g. en, en-gb). Optional.
HUBSPOT_KB_LANGUAGE=
# Optional: public sitemap URL for the knowledge base (fallback if API access fails).
HUBSPOT_KB_PUBLIC_SITEMAP_URL=
# HubDB table id for video library items (Content Hub Pro/Ent).
HUBSPOT_VIDEOS_HUBDB_TABLE_ID=
# Optional: folder id to store generated thumbnails in HubSpot Files.
HUBSPOT_VIDEO_THUMBNAILS_FOLDER_ID=
# Optional: folder path to store generated thumbnails (used if folder id is blank).
HUBSPOT_VIDEO_THUMBNAILS_FOLDER_PATH=/
# Optional: frame time in seconds for thumbnail capture.
HUBSPOT_VIDEO_THUMBNAILS_FRAME_SECONDS=1

# Brief constraint: never update company name for existing contacts.
# If/when you map HubSpot properties, keep company name out of update payloads.

# Event email timing defaults (must be configurable; not hardcoded)
EVENT_REMINDER_LEAD_TIME_HOURS=48
EVENT_THANK_YOU_DELAY_HOURS=24

# Admin (required to use /admin/* endpoints)
# Comma-separated list of email addresses that are allowed to access admin settings.
ADMIN_EMAIL_ALLOWLIST=

# Background jobs (email scheduling/worker)
EMAIL_JOBS_ENABLED=true
EMAIL_JOBS_POLL_INTERVAL_MS=5000
EMAIL_JOBS_BATCH_SIZE=10
EMAIL_JOBS_MAX_ATTEMPTS=5

# Stripe
STRIPE_SECRET_KEY=

# Stripe webhook (used by POST /stripe/webhook)
STRIPE_WEBHOOK_SECRET=

# Optional overrides (otherwise derived from PORTAL_BASE_URL)
STRIPE_CHECKOUT_SUCCESS_URL=
STRIPE_CHECKOUT_CANCEL_URL=

# QuickBooks
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=

# SMTP (optional)
# If configured, the API will send real email login codes.
# In development without SMTP, login codes are returned as `devCode` from POST /auth/start.
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
